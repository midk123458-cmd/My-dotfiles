{
  "layer": "top",
  "position": "top",
  "margin-bottom": 2,
  "spacing" : 0,
  "exclusive": true,
  "modules-left": [
  "custom/launcher",
  "hyprland/workspaces",
  "cpu",
  "memory",
  ],

  "modules-center": [
  "clock"
  ],

  "modules-right": [
    "bluetooth",
    "network",
    "pulseaudio", 
    "backlight",
    "battery",
  ],

  "hyprland/workspaces": {
    "format": "{name}: {icon}",
